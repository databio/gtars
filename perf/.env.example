# gtars-perf data configuration.
#
# Copy this file to perf/.env and set PERF_DATA_URL to the public location of
# the fixture tarball (perfdata-v1.tar.gz). perf.py reads this file (or the
# process environment) and downloads + caches the tarball on a fresh checkout
# when neither perf/data/ nor perf/perfdata-v1.tar.gz is present.
#
# The tarball must be uploaded to cloud storage (S3/GCS/HTTP/etc.) and made
# readable by whoever runs the suite.
PERF_DATA_URL=https://cloud.databio.org/gtars/perfdata-v1.tar.gz
